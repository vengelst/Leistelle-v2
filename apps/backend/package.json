{
  "name": "@leitstelle/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@leitstelle/config": "0.1.0",
    "@leitstelle/contracts": "0.1.0",
    "@leitstelle/observability": "0.1.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "npm run build && node dist/index.js",
    "migrate": "npm run build && node dist/scripts/migrate.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "smoke:test": "npm run build && node --test dist/tests/smoke.test.js",
    "monitoring:scan": "npm run build && node dist/scripts/monitoring-scan.js"
  }
}
