# Stagebetrieb: Platzhalter vor Inbetriebnahme mit Stage-Werten ersetzen.
COMPOSE_PROJECT_NAME=leitstelle-stage
NODE_ENV=production
APP_VERSION=stage-2026-04

# Backend HTTP
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
HTTP_TRUST_PROXY=true
FRONTEND_ORIGIN=https://stage.leitstelle.vivahome.de
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PUBLIC_PORT=28080
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_PUBLIC_PORT=4273
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PUBLIC_PORT=55441

# Datenbank
POSTGRES_DB=leitstelle
POSTGRES_USER=leitstelle
POSTGRES_PASSWORD=CHANGE_ME_STAGE_DB_CONTAINER_PASSWORD
DATABASE_URL=postgres://leitstelle:CHANGE_ME_STAGE_DB_USER_PASSWORD@127.0.0.1:5432/leitstelle

# Auth
AUTH_SESSION_TTL_HOURS=8
AUTH_BOOTSTRAP_PASSWORD=CHANGE_ME_STAGE_BOOTSTRAP_PASSWORD
ALLOW_DESTRUCTIVE_SEED=false

# Externe Alarm-/Medien-Ingestion
ALARM_EXTERNAL_INGESTION_SHARED_SECRET=CHANGE_ME_STAGE_ALARM_INGESTION_SECRET
ALARM_EXTERNAL_MEDIA_INGESTION_SHARED_SECRET=CHANGE_ME_STAGE_MEDIA_INGESTION_SECRET

# Medienkorrelation
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_SECONDS=30
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_GRUNDIG_SECONDS=
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_DAHUA_SECONDS=
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_HIKVISION_SECONDS=
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_AJAX_SECONDS=

# Medien-Storage
MEDIA_STORAGE_TYPE=filesystem
MEDIA_STORAGE_BASE_URL=https://stage.leitstelle.vivahome.de/media
MEDIA_STORAGE_LOCAL_PATH=/opt/leitstelle-stage/media

# Frontend-Build/Proxy
FRONTEND_API_BASE_URL=https://stage.leitstelle.vivahome.de

# Operativer Worker
WORKER_MONITORING_ENABLED=true
WORKER_MONITORING_INTERVAL_SECONDS=30
WORKER_MONITORING_RUN_ON_STARTUP=true

# Optional
ALARM_AUTO_ASSIGNMENT_LIGHT_ENABLED=false
BACKUP_RETENTION_DAYS=30
