# Pilotbetrieb: alle Platzhalter vor Inbetriebnahme mit echten Werten ersetzen.
NODE_ENV=production
APP_VERSION=pilot-2026-04

# Backend HTTP
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
HTTP_TRUST_PROXY=true
FRONTEND_ORIGIN=https://leitstelle.vivahome.de
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PUBLIC_PORT=18080
FRONTEND_BIND_HOST=127.0.0.1
FRONTEND_PUBLIC_PORT=4173
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PUBLIC_PORT=55440

# Datenbank
POSTGRES_DB=leitstelle
POSTGRES_USER=leitstelle
POSTGRES_PASSWORD=CHANGE_ME_DB_CONTAINER_PASSWORD
DATABASE_URL=postgres://leitstelle:CHANGE_ME_DB_USER_PASSWORD@127.0.0.1:5432/leitstelle

# Auth
AUTH_SESSION_TTL_HOURS=8
# Pflichtwert: kein Default-Passwort verwenden, sonst startet das Backend in production nicht.
AUTH_BOOTSTRAP_PASSWORD=CHANGE_ME_LONG_RANDOM_BOOTSTRAP_PASSWORD
ALLOW_DESTRUCTIVE_SEED=false

# Externe Alarm-/Medien-Ingestion
ALARM_EXTERNAL_INGESTION_SHARED_SECRET=CHANGE_ME_ALARM_INGESTION_SECRET
ALARM_EXTERNAL_MEDIA_INGESTION_SHARED_SECRET=CHANGE_ME_MEDIA_INGESTION_SECRET

# Medienkorrelation
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_SECONDS=30
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_GRUNDIG_SECONDS=
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_DAHUA_SECONDS=
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_HIKVISION_SECONDS=
ALARM_EXTERNAL_MEDIA_CORRELATION_TOLERANCE_AJAX_SECONDS=

# Medien-Storage: referenzbasierter Zugriff, kein internes Blob-Subsystem
MEDIA_STORAGE_TYPE=filesystem
MEDIA_STORAGE_BASE_URL=https://leitstelle.vivahome.de/media
MEDIA_STORAGE_LOCAL_PATH=/opt/leitstelle/media

# Frontend-Build/Proxy
FRONTEND_API_BASE_URL=https://leitstelle.vivahome.de

# Operativer Worker
WORKER_MONITORING_ENABLED=true
WORKER_MONITORING_INTERVAL_SECONDS=30
WORKER_MONITORING_RUN_ON_STARTUP=true

# Optional: bleibt im Pilot standardmaessig deaktiviert
ALARM_AUTO_ASSIGNMENT_LIGHT_ENABLED=false

# Aufbewahrung serverseitiger Postgres-Backups in Tagen
BACKUP_RETENTION_DAYS=30
